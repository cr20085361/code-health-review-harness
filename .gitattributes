# Normalize line endings to LF in the repo, check out as-is on Windows.
* text=auto eol=lf

# PowerShell scripts: text, LF
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# Markdown / JSON / YAML: text, LF
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Linguist hints
*.ps1 linguist-language=PowerShell
